VITE_LOGGER_LEVEL=debug
VITE_GOOGLE_API_KEY=your-development-api-key-here
VITE_CESIUM_ION_TOKEN=your-development-cesium-ion-token-here

# Override if you want 
VITE_BASE_URL=""

VITE_MAP_MODE="map-server"
VITE_DISCOVERY_SUFFIX="loc.open-flame.com."

# Dev map-server mode
VITE_API_LIST_MAPS="/api/maps"
VITE_MAPS_SERVICES_BASE="/maps"
# Localhost proxy for development. Leave blank to use a mock api loading from JSON file
VITE_DEFAULT_MAP_SERVER="cmu-mapserver.open-flame.com"
